#!/usr/bin/env bash
# Install-free launcher for the-office CLI.
#
# Claude Code does not add a plugin's bin/ to $PATH, so the skill invokes this
# wrapper by absolute path via "${CLAUDE_PLUGIN_ROOT}/bin/the-office". It runs
# the CLI without requiring the user to separately `pipx install the-office-cli`
# — uvx/pipx fetch and cache the package on first use, then run its `the-office`
# entry point.
set -euo pipefail

if command -v uvx >/dev/null 2>&1; then
  exec uvx --from the-office-cli the-office "$@"
elif command -v pipx >/dev/null 2>&1; then
  exec pipx run --spec the-office-cli the-office "$@"
else
  echo "the-office: needs 'uv' (recommended) or 'pipx' installed to run." >&2
  echo "  Install uv:   https://docs.astral.sh/uv/getting-started/installation/" >&2
  echo "  Install pipx: https://pipx.pypa.io/stable/installation/" >&2
  exit 127
fi
